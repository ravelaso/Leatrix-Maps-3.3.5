<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">
	<!-- LeaMapsGlobalPinTemplate removed: BaseHighlightableMapPoiPinTemplate does not exist in 3.3.5 -->
	<!-- POI pins are created programmatically as plain textures on WorldMapDetailFrame -->

	<!-- Zoom: scrollable container that wraps WorldMapDetailFrame -->
	<ScrollFrame name="WorldMapScrollFrame" parent="WorldMapFrame" inherits="FauxScrollFrameTemplate">
		<Size>
			<AbsDimension x="1002" y="668" />
		</Size>
		<Anchors>
			<Anchor point="TOPLEFT" relativePoint="TOPLEFT" relativeTo="WorldMapPositioningGuide"/>
		</Anchors>
	</ScrollFrame>

	<!-- Zoom: slider template used by the options panel -->
	<Slider name="MagnifySliderTemplate" inherits="OptionsSliderTemplate" virtual="true">
		<Size x="250" y="17"/>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentCurrentValueText" inherits="GameFontNormalSmall">
					<Anchors>
						<Anchor point="BOTTOM">
							<Offset x="0" y="-8"/>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Slider>
</Ui>
